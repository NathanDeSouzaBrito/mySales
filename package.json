    "@typescript-eslint/parser": "^8.58.2",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
